generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DIETITIAN
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

enum PatientCategory {
  PEDIATRIC
  DIABETIC
  LOW_INCOME
  OBESE
  ELDERLY
  ATHLETE
}

model User {
  id           Int             @id @default(autoincrement())
  name         String
  email        String          @unique
  passwordHash String
  role         Role            @default(DIETITIAN)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  reports      PatientReport[]
  dietPlans    DietPlan[]
}

model PatientReport {
  id              Int             @id @default(autoincrement())
  userId          Int
  patientCategory PatientCategory
  data            Json
  createdAt       DateTime        @default(now())
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  dietPlans       DietPlan[]
}

model Food {
  id            Int               @id @default(autoincrement())
  name          String
  category      String
  calories      Float
  protein       Float
  carbs         Float
  fat           Float
  portionGram   Float
  equivalentsA  FoodEquivalence[] @relation("FoodA")
  equivalentsB  FoodEquivalence[] @relation("FoodB")
  dietPlanItems DietPlanItem[]
}

model FoodEquivalence {
  id              Int    @id @default(autoincrement())
  foodAId         Int
  foodBId         Int
  equivalentRatio Float
  group           String?
  foodA           Food   @relation("FoodA", fields: [foodAId], references: [id], onDelete: Cascade)
  foodB           Food   @relation("FoodB", fields: [foodBId], references: [id], onDelete: Cascade)
}

model DietPlan {
  id               Int             @id @default(autoincrement())
  userId           Int
  patientReportId  Int?
  patientCategory  PatientCategory
  requiredCalories Float
  totalCalories    Float
  totalProtein     Float
  totalCarbs       Float
  totalFat         Float
  score            Float
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  patientReport    PatientReport?  @relation(fields: [patientReportId], references: [id], onDelete: SetNull)
  items            DietPlanItem[]
}

model DietPlanItem {
  id                Int      @id @default(autoincrement())
  dietPlanId        Int
  foodId            Int
  mealType          MealType
  portionMultiplier Float    @default(1)
  dietPlan          DietPlan @relation(fields: [dietPlanId], references: [id], onDelete: Cascade)
  food              Food     @relation(fields: [foodId], references: [id], onDelete: Cascade)
}
